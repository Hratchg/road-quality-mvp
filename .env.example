# .env.example — environment variable template for road-quality-mvp
#
# Copy this file to .env and fill in any values you want to override.
# .env is git-ignored; .env.example is committed.
#
# Variables listed here match what the codebase currently reads (backend, frontend, scripts).
# Future M1 phases will extend this file as new env vars are introduced.

# ----- Database -----
# Consumed by: backend/app/db.py, scripts/seed_data.py, scripts/compute_scores.py, scripts/ingest_iri.py
# The dev default below matches docker-compose.yml. Replace with your cloud DB URL in production (Phase 5).
DATABASE_URL=postgresql://rq:rqpass@localhost:5432/roadquality

# ----- Frontend -> Backend API -----
# Consumed by: frontend/src/api.ts (import.meta.env.VITE_API_URL)
# In local Vite dev, the dev-server proxies /api to the backend — leave blank or set to an absolute URL.
# In Docker Compose, docker-compose.yml sets this to http://localhost:8000.
# In production (Phase 5), set this to the deployed backend origin.
VITE_API_URL=http://localhost:8000

# ----- Mapbox (optional, Phase 5+ frontend tile upgrade) -----
# Consumed by: frontend (not yet wired; currently declared empty in docker-compose.yml)
# Leave blank to use the default Leaflet+OSM tiles. Set to a real Mapbox token to enable premium tiles.
# NEVER commit a real token to git — this template stays empty.
VITE_MAPBOX_TOKEN=

# ----- YOLOv8 Detector Model -----
# Consumed by: data_pipeline/detector_factory.py
# Either an HF repo id ("user/repo" or "user/repo:filename.pt" or "user/repo@revision")
# OR a local .pt file path ("./models/my.pt" or "/abs/path.pt").
# If unset, the factory uses the default HF repo baked into detector_factory.py
# (currently: keremberke/yolov8s-pothole-segmentation).
# Pin to a specific @revision in production to avoid silent weight swaps (see Pitfall 8
# in .planning/phases/02-real-data-detector-accuracy/02-RESEARCH.md).
YOLO_MODEL_PATH=

# ----- HuggingFace Hub (fine-tune upload only) -----
# Consumed by: scripts/finetune_detector.py (--push flag)
# Create a write-scope token at https://huggingface.co/settings/tokens.
# NEVER commit a real token. Leave empty if you will not be publishing fine-tunes.
HUGGINGFACE_TOKEN=
